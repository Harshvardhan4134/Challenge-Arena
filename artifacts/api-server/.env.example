PORT=3000
NODE_ENV=development

# Point this to your downloaded Firebase service account JSON
GOOGLE_APPLICATION_CREDENTIALS=C:/Users/srava/OneDrive/Desktop/CA/CA/challenge-arena-freefire-firebase-adminsdk-fbsvc-1d7b7d7111.json

# Match proof uploads (required in production). Use the exact bucket name from Firebase Console → Storage.
# Examples: your-project.appspot.com OR your-project.firebasestorage.app
# FIREBASE_STORAGE_BUCKET=
# If you use env vars instead of a JSON file, set these (Render):
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# For newer Firebase projects whose default bucket ends in .firebasestorage.app, either set FIREBASE_STORAGE_BUCKET
# or set: FIREBASE_STORAGE_BUCKET_DOMAIN=firebasestorage.app

# Match result screenshots: default = Firestore (Spark / no Cloud Storage upgrade). Optional absolute API URL for proof links:
# API_PUBLIC_URL=https://your-api.onrender.com
# (Render also works with RENDER_EXTERNAL_URL; trust proxy is enabled.)
# To use Firebase Storage instead (Blaze): RESULT_PROOF_USE_FIREBASE_STORAGE=true

# Third-party Free Fire profile lookup (quick MVP)
FREEFIRE_LOOKUP_BASE_URL=https://developers.freefirecommunity.com
FREEFIRE_LOOKUP_REGION=IND
# Strongly recommended in production: public mirrors are often404/402/disabled.
# Register at Free Fire Community / developer API and set the key here.
FREEFIRE_LOOKUP_API_KEY=
FREEFIRE_LOOKUP_PUBLIC_BASE_URL=https://freefireinfo-zy9l.onrender.com
# Optional comma-separated extra mirrors (tried after legacy host). Many public hosts break without notice.
FREEFIRE_LOOKUP_PUBLIC_MIRRORS=https://free-ff-api-src-5plp.onrender.com
# Optional lookup tuning
FREEFIRE_LOOKUP_TIMEOUT_MS=8000
FREEFIRE_LOOKUP_CACHE_TTL_MS=300000

# Comma-separated usernames and/or emails (any entry with @ is treated as email).
# ADMIN_EMAILS: also grants admin when username equals the email local-part (before @), for Google signups.
# Production API (e.g. Render) must define these env vars.
# Alternatively set isAdmin: true on the user document in Firestore.
ADMIN_USERNAMES=
ADMIN_EMAILS=

# Optional browser push (Web Push). If unset, /api/notifications/push/vapid-public-key returns 200 with configured:false (no console 503).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@example.com

# WhatsApp alerts (Twilio WhatsApp “bot” style messages). Users must save a valid phone on Profile.
# Sandbox: join Twilio sandbox from your phone, then TWILIO_WHATSAPP_FROM=whatsapp:+14155238886 (example).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+1xxxxxxxxxx
